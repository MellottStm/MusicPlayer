<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="550.0" prefWidth="850.0" styleClass="search-root" stylesheets="@../styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smt.UI.SearchView">
   <children>
      <TextField fx:id="searchField" layoutX="234.0" layoutY="42.0" prefHeight="42.0" prefWidth="332.0" promptText="输入你要搜索的音乐" styleClass="search-textfield" stylesheets="@../styles.css" />
      <Button fx:id="searchButton" layoutX="537.0" layoutY="42.0" mnemonicParsing="false" onAction="#handleSearch" prefHeight="42.0" prefWidth="96.0" styleClass="search-button" stylesheets="@../styles.css" text="搜索" textAlignment="JUSTIFY" textFill="WHITE" />
      <ListView fx:id="searchList" layoutY="100.0" prefHeight="389.0" prefWidth="850.0" styleClass="music-list-view" stylesheets="@../styles.css" />
      <ProgressIndicator fx:id="loadingIndicator" layoutX="414.0" layoutY="256.0" visible="false" />
      <AnchorPane fx:id="playCard" layoutY="497.0" prefHeight="53.0" prefWidth="850.0" styleClass="play-card" stylesheets="@../styles.css">
         <children>
            <Button fx:id="playBtn" layoutX="729.0" layoutY="9.0" mnemonicParsing="false" prefHeight="36.0" prefWidth="38.0" styleClass="play-button" stylesheets="@../styles.css" />
            <Button fx:id="beforeBtn" layoutX="688.0" layoutY="15.0" mnemonicParsing="false" prefHeight="20.0" prefWidth="28.0" styleClass="before-button" stylesheets="@../styles.css" />
            <Button fx:id="nextBtn" layoutX="781.0" layoutY="15.0" mnemonicParsing="false" prefHeight="23.0" prefWidth="28.0" styleClass="next-button" stylesheets="@../styles.css" />
            <ImageView fx:id="cover" fitHeight="36.0" fitWidth="38.0" layoutX="27.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true" />
            <Label fx:id="msg" layoutX="139.0" layoutY="19.0" prefHeight="20.0" prefWidth="484.0" styleClass="music-song" stylesheets="@../styles.css"  />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
