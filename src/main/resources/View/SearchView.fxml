<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="550.0" prefWidth="850.0" styleClass="search-root" stylesheets="@../styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smt.UI.SearchView">
   <children>
      <TextField fx:id="searchField" layoutX="13.0" layoutY="14.0" prefHeight="42.0" prefWidth="823.0" promptText="输入你要搜索的音乐" styleClass="search-textfield" stylesheets="@../styles.css" />
      <Button fx:id="searchButton" layoutX="740.0" layoutY="14.0" mnemonicParsing="false" onAction="#handleSearch" prefHeight="42.0" prefWidth="96.0" styleClass="search-button" stylesheets="@../styles.css" text="搜索" textAlignment="JUSTIFY" textFill="WHITE" />
      <ListView fx:id="searchList" layoutY="70.0" prefHeight="427.0" prefWidth="850.0" styleClass="music-list-view" stylesheets="@../styles.css" />
      <ProgressIndicator fx:id="loadingIndicator" layoutX="414.0" layoutY="256.0" visible="false" />
      <AnchorPane fx:id="playCard" layoutY="497.0" prefHeight="53.0" prefWidth="850.0" styleClass="play-card" stylesheets="@../styles.css">
         <children>
            <Button fx:id="playBtn" layoutX="406.0" layoutY="9.0" mnemonicParsing="false" prefHeight="36.0" prefWidth="38.0" styleClass="play-button" stylesheets="@../styles.css" visible="false" />
            <Button fx:id="beforeBtn" layoutX="365.0" layoutY="15.0" mnemonicParsing="false" prefHeight="20.0" prefWidth="28.0" styleClass="before-button" stylesheets="@../styles.css" visible="false" />
            <Button fx:id="nextBtn" layoutX="458.0" layoutY="15.0" mnemonicParsing="false" prefHeight="23.0" prefWidth="28.0" styleClass="next-button" stylesheets="@../styles.css" visible="false" />
            <ImageView fx:id="cover" fitHeight="36.0" fitWidth="38.0" layoutX="27.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true" />
            <Label fx:id="msg" layoutX="156.0" layoutY="17.0" prefHeight="20.0" prefWidth="175.0" styleClass="music-song" stylesheets="@../styles.css" />
            <Button fx:id="collectedListBtn" layoutX="808.0" layoutY="15.0" mnemonicParsing="false" prefHeight="20.0" prefWidth="28.0" styleClass="play-list-button" stylesheets="@../styles.css" />
            <Button fx:id="isCollectedBtn" layoutX="99.0" layoutY="17.0" mnemonicParsing="false" prefHeight="23.0" prefWidth="28.0" styleClass="is-collected-button" stylesheets="@../styles.css" visible="false" />
         </children>
      </AnchorPane>
      <AnchorPane fx:id="playView" prefHeight="550.0" prefWidth="850.0" styleClass="search-root" stylesheets="@../styles.css" visible="false">
         <children>
            <ImageView fx:id="playViewCoverImage" fitHeight="269.0" fitWidth="273.0" layoutX="152.0" layoutY="95.0" pickOnBounds="true" preserveRatio="true" />
            <Label fx:id="playViewSong" layoutX="471.0" layoutY="172.0" styleClass="music-singer" stylesheets="@../styles.css" text="歌手" />
            <Label fx:id="playViewSinger" layoutX="471.0" layoutY="230.0" styleClass="music-singer" stylesheets="@../styles.css" text="歌名" />
            <Label fx:id="playViewDuration" layoutX="34.0" layoutY="415.0" styleClass="music-singer" stylesheets="@../styles.css" text="00:00" />
            <Label fx:id="playViewCurrentDuration" layoutX="777.0" layoutY="413.0" styleClass="music-singer" stylesheets="@../styles.css" text="00:00" />
            <Button fx:id="playViewBeforeBtn" alignment="CENTER" contentDisplay="CENTER" layoutX="29.0" layoutY="482.0" mnemonicParsing="false" prefHeight="31.0" prefWidth="29.0" styleClass="before-button" stylesheets="@../styles.css" textAlignment="JUSTIFY" />
            <Button fx:id="playViewPlayBtn" layoutX="74.0" layoutY="475.0" mnemonicParsing="false" prefHeight="46.0" prefWidth="44.0" styleClass="play-button" stylesheets="@../styles.css" />
            <Button fx:id="playViewNextBtn" layoutX="131.0" layoutY="482.0" mnemonicParsing="false" prefHeight="31.0" prefWidth="44.0" styleClass="next-button" stylesheets="@../styles.css" />
            <Button fx:id="playViewPlayModBtn" layoutX="795.0" layoutY="482.0" mnemonicParsing="false" prefHeight="31.0" prefWidth="44.0" styleClass="play-mod-button" stylesheets="@../styles.css" />
            <Button fx:id="playViewListBtn" layoutX="22.0" layoutY="20.0" mnemonicParsing="false" prefHeight="31.0" prefWidth="35.0" styleClass="close-play-list-button" stylesheets="@../styles.css" />
            <Slider fx:id="playViewProgressSlider" layoutX="75.0" layoutY="415.0" min="0.0" prefHeight="14.0" prefWidth="696.0" />
            <Button fx:id="playViewIsCollectedBtn" layoutX="736.0" layoutY="479.0" mnemonicParsing="false" prefHeight="38.0" prefWidth="35.0" styleClass="is-collected-button" stylesheets="@../styles.css" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
